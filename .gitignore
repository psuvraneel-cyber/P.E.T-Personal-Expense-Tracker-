# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# Secrets — never commit API keys or signing credentials
.env
android/key.properties
*.jks
*.keystore

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Platform ephemeral directories (regenerated by flutter pub get)
**/windows/flutter/ephemeral/
**/ios/Flutter/ephemeral/
**/linux/flutter/ephemeral/

# Android build caches
/android/.gradle/
/android/app/build/

# Temp files
tmpclaude-*

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Build helper (local utility)
build_helper.ps1
build.bat
node_modules
